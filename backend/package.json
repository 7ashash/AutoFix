{
  "name": "autofix-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:init": "node src/scripts/init-db.js",
    "db:seed": "node src/scripts/seed-db.js",
    "db:migrate": "node src/scripts/migrate-db.js",
    "db:runtime:start": "node src/scripts/start-mysql-runtime.js",
    "db:runtime:stop": "node src/scripts/stop-mysql-runtime.js",
    "db:runtime:ping": "node src/scripts/ping-mysql-runtime.js",
    "phase4:smoke": "node src/scripts/smoke-test-phase4.js",
    "phase5:smoke": "node src/scripts/smoke-test-phase5.js",
    "phase6:smoke": "node src/scripts/smoke-test-phase6.js",
    "phase7:smoke": "node src/scripts/smoke-test-phase7.js",
    "phase8:smoke": "node src/scripts/smoke-test-phase8.js",
    "phase9:smoke": "node src/scripts/smoke-test-phase9.js",
    "dev:stack": "powershell.exe -ExecutionPolicy Bypass -File ./scripts/run-dev-stack.ps1",
    "data:prepare-production": "node src/scripts/prepare-production-data.js",
    "check": "node --check src/server.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.14.1",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
